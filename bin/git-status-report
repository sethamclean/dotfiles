#!/bin/bash

set -u

usage() {
  cat <<'EOF'
Usage: git-status-report [--no-color] [--color=auto|always|never]

Options:
  --no-color      Disable color output
  --color=MODE    Set color mode (auto, always, never)
EOF
}

is_number() {
  [[ "$1" =~ ^[0-9]+$ ]]
}

color_mode="auto"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-color)
      color_mode="never"
      ;;
    --color=auto|--color=always|--color=never)
      color_mode="${1#--color=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf "Unknown option: %s\n\n" "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

colors_enabled=false
case "$color_mode" in
  always)
    colors_enabled=true
    ;;
  never)
    colors_enabled=false
    ;;
  auto)
    if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-}" != "dumb" ]; then
      colors_enabled=true
    fi
    ;;
esac

if [ "$colors_enabled" = true ]; then
  if command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || printf 0)" -ge 8 ]; then
    RESET="$(tput sgr0)"
    BOLD="$(tput bold)"
    DIM="$(tput dim)"
    RED="$(tput setaf 1)"
    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"
    BLUE="$(tput setaf 4)"
    CYAN="$(tput setaf 6)"
  else
    RESET='\033[0m'
    BOLD='\033[1m'
    DIM='\033[2m'
    RED='\033[31m'
    GREEN='\033[32m'
    YELLOW='\033[33m'
    BLUE='\033[34m'
    CYAN='\033[36m'
  fi
else
  RESET=""
  BOLD=""
  DIM=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  CYAN=""
fi

paint() {
  local color="$1"
  local text="$2"
  printf "%b%s%b" "$color" "$text" "$RESET"
}

color_count() {
  local value="$1"
  local severity="$2"

  if [ "$value" = "-" ] || [ "$value" = "N/A" ]; then
    paint "$DIM" "$value"
    return
  fi

  if ! is_number "$value"; then
    paint "$DIM" "$value"
    return
  fi

  if [ "$value" -eq 0 ]; then
    paint "$GREEN" "$value"
  elif [ "$severity" = "high" ]; then
    paint "$RED" "$value"
  else
    paint "$YELLOW" "$value"
  fi
}

color_branch() {
  local value="$1"
  if [ "$value" = "-" ]; then
    paint "$DIM" "$value"
  elif [ "$value" = "main" ] || [ "$value" = "master" ]; then
    paint "$GREEN" "$value"
  else
    paint "$YELLOW" "$value"
  fi
}

color_repo_type() {
  local value="$1"
  if [ "$value" = "git" ]; then
    paint "$BLUE" "$value"
  else
    paint "$DIM" "$value"
  fi
}

color_directory_name() {
  local value="$1"
  local severity="$2"

  case "$severity" in
    high)
      paint "$RED" "$value"
      ;;
    warn)
      paint "$YELLOW" "$value"
      ;;
    clean)
      paint "$GREEN" "$value"
      ;;
    *)
      paint "$DIM" "$value"
      ;;
  esac
}

status_token() {
  local icon="$1"
  local value="$2"
  local severity="$3"

  if [ "$value" = "-" ] || [ "$value" = "N/A" ]; then
    paint "$DIM" "${icon}-"
    return
  fi

  if ! is_number "$value"; then
    paint "$DIM" "${icon}${value}"
    return
  fi

  if [ "$value" -eq 0 ]; then
    paint "$GREEN" "${icon}${value}"
  elif [ "$severity" = "high" ]; then
    paint "$RED" "${icon}${value}"
  else
    paint "$YELLOW" "${icon}${value}"
  fi
}

# Summary counters
total_dirs=0
total_git=0
total_non_git=0
repos_untracked=0
repos_modified=0
repos_staged=0
repos_behind=0
repos_non_default_branch=0
repos_clean=0

printf "Git Repository Status Report\n"
printf "Generated on %s\n" "$(date)"
printf "Scanning repositories in %s\n\n" "$(pwd)"

locale_tag="${LC_ALL:-${LC_CTYPE:-${LANG:-}}}"
if [[ "$locale_tag" == *"UTF-8"* ]] || [[ "$locale_tag" == *"utf8"* ]] || [[ "$locale_tag" == *"utf-8"* ]]; then
  ICON_UNTRACKED="?"
  ICON_MODIFIED="~"
  ICON_STAGED="+"
  ICON_BEHIND="⇣"
else
  ICON_UNTRACKED="?"
  ICON_MODIFIED="~"
  ICON_STAGED="+"
  ICON_BEHIND="v"
fi

table_rows=()
table_rows+=("Repo\tStatus\tBranch\tDirectory")

for dir in */; do
  [ -d "$dir" ] || continue

  dir=${dir%/}
  total_dirs=$((total_dirs + 1))

  if ! git -C "$dir" rev-parse --git-dir >/dev/null 2>&1; then
    total_non_git=$((total_non_git + 1))

    repo_cell="$(color_repo_type dir)"
    untracked_cell="$(color_count - low)"
    modified_cell="$(color_count - low)"
    staged_cell="$(color_count - low)"
    behind_cell="$(color_count - high)"
    status_cell="$(paint "$DIM" "-")"
    branch_cell="$(color_branch -)"
    directory_cell="$(color_directory_name "$dir" na)"

    table_rows+=("$repo_cell\t$status_cell\t$branch_cell\t$directory_cell")
    continue
  fi

  total_git=$((total_git + 1))

  untracked_count=$(git -C "$dir" ls-files --others --exclude-standard | wc -l | tr -d ' ')
  modified_count=$(git -C "$dir" diff --name-only | wc -l | tr -d ' ')
  staged_count=$(git -C "$dir" diff --cached --name-only | wc -l | tr -d ' ')
  current_branch=$(git -C "$dir" branch --show-current 2>/dev/null)
  if [ -z "$current_branch" ]; then
    current_branch="DETACHED"
  fi

  default_remote_head=$(git -C "$dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || printf "")
  if [ -n "$default_remote_head" ] && git -C "$dir" show-ref --verify --quiet "refs/remotes/${default_remote_head}"; then
    behind_count=$(git -C "$dir" rev-list HEAD.."${default_remote_head}" --count 2>/dev/null || printf "N/A")
  elif git -C "$dir" show-ref --verify --quiet refs/remotes/origin/main; then
    behind_count=$(git -C "$dir" rev-list HEAD..origin/main --count 2>/dev/null || printf "N/A")
  elif git -C "$dir" show-ref --verify --quiet refs/remotes/origin/master; then
    behind_count=$(git -C "$dir" rev-list HEAD..origin/master --count 2>/dev/null || printf "N/A")
  else
    behind_count="N/A"
  fi

  has_issues=false

  if [ "$untracked_count" -gt 0 ]; then
    repos_untracked=$((repos_untracked + 1))
    has_issues=true
  fi

  if [ "$modified_count" -gt 0 ]; then
    repos_modified=$((repos_modified + 1))
    has_issues=true
  fi

  if [ "$staged_count" -gt 0 ]; then
    repos_staged=$((repos_staged + 1))
    has_issues=true
  fi

  if is_number "$behind_count" && [ "$behind_count" -gt 0 ]; then
    repos_behind=$((repos_behind + 1))
    has_issues=true
  fi

  if [ "$current_branch" != "master" ] && [ "$current_branch" != "main" ]; then
    repos_non_default_branch=$((repos_non_default_branch + 1))
    has_issues=true
  fi

  if [ "$has_issues" = false ]; then
    repos_clean=$((repos_clean + 1))
  fi

  repo_cell="$(color_repo_type git)"
  untracked_cell="$(color_count "$untracked_count" low)"
  modified_cell="$(color_count "$modified_count" low)"
  staged_cell="$(color_count "$staged_count" low)"
  behind_cell="$(color_count "$behind_count" high)"
  status_cell="$(status_token "$ICON_UNTRACKED" "$untracked_count" low) $(status_token "$ICON_MODIFIED" "$modified_count" low) $(status_token "$ICON_STAGED" "$staged_count" low) $(status_token "$ICON_BEHIND" "$behind_count" high)"
  branch_cell="$(color_branch "$current_branch")"

  dir_severity="clean"
  if is_number "$behind_count" && [ "$behind_count" -gt 0 ]; then
    dir_severity="high"
  elif [ "$untracked_count" -gt 0 ] || [ "$modified_count" -gt 0 ] || [ "$staged_count" -gt 0 ]; then
    dir_severity="warn"
  elif [ "$current_branch" != "master" ] && [ "$current_branch" != "main" ]; then
    dir_severity="warn"
  fi
  directory_cell="$(color_directory_name "$dir" "$dir_severity")"

  table_rows+=("$repo_cell\t$status_cell\t$branch_cell\t$directory_cell")
done

if command -v column >/dev/null 2>&1; then
  table_output=$(printf "%b\n" "${table_rows[@]}" | column -t -s $'\t')
else
  table_output=$(printf "%b\n" "${table_rows[@]}")
fi

if [ "$colors_enabled" = true ]; then
  header_printed=""
  while IFS= read -r line; do
    if [ -z "$header_printed" ]; then
      printf "%b%s%b\n" "${BOLD}${CYAN}" "$line" "$RESET"
      header_printed=1
    else
      printf "%b\n" "$line"
    fi
  done <<< "$table_output"
else
  printf "%s\n" "$table_output"
fi

printf "Legend: %s untracked  %s modified  %s staged  %s behind\n" \
  "${ICON_UNTRACKED}N" "${ICON_MODIFIED}N" "${ICON_STAGED}N" "${ICON_BEHIND}N"

printf "\n%b%s%b\n" "${BOLD}${CYAN}" "Summary" "$RESET"
printf "Directories: %d total | %d git | %d non-git\n" "$total_dirs" "$total_git" "$total_non_git"
printf "Categories: untracked=%d modified=%d staged=%d behind=%d non-default-branch=%d clean=%d\n" \
  "$repos_untracked" "$repos_modified" "$repos_staged" "$repos_behind" "$repos_non_default_branch" "$repos_clean"
