[alias]
	br = !git branch --all --color=always --sort=-committerdate | sed 's/^..//' | fzf --ansi --layout=reverse --height=80% --preview 'git --no-pager log --oneline --decorate --color=always -n 20 {1}' --preview-window=right:70%:wrap | sed 's%^remotes/[^/]*/%%' | xargs -r git checkout
	d = difftool
	hist = log --graph --decorate --date=relative --pretty=format:'%C(auto)%h%d %s %C(black)%C(bold)%cr %C(blue)<%an>'
	hist-all = log --all --graph --decorate --date=short --pretty=format:'%C(auto)%h%d %s %C(black)%C(bold)%cd %C(blue)<%an>'
	hist-file = log --follow --date=short --pretty=format:'%C(auto)%h %C(black)%C(bold)%cd%Creset %s %C(blue)<%an>' --
	hist-main = log --left-right --cherry --graph --oneline main...HEAD
	showpick = !git log --date=short --pretty=format:'%h %C(blue)%cd%Creset %s %C(black)%C(bold)<%an>' --color=always "$@" | fzf --ansi --layout=reverse --height=80% --preview 'git --no-pager show --color=always --stat {1}' --preview-window=right:70%:wrap | awk '{print $1}' | xargs -r git show --color=always
	st = status --short --branch
	status-report = !git --no-pager diff --stat && git --no-pager status -s
	tree = log --oneline --graph --color --all --decorate

[branch]
	sort = -committerdate

[column]
	ui = auto
	branch = auto

[commit]
	template = ~/.config/git/hooks/commit.template

[core]
	editor = nvim
	excludesfile = ~/.config/git/ignore
	hooksPath = ~/.config/git/hooks
	pager = delta

[credential "https://gist.github.com"]
	helper = !gh auth git-credential

[credential "https://github.com"]
	helper = !gh auth git-credential

[delta]
	commit-decoration-style = none
	dark = true
	file-decoration-style = none
	file-style = "#cdd6f4"
	hunk-header-decoration-style = none
	hunk-header-file-style = "#cdd6f4" bold
	hunk-header-line-number-style = "#bac2de"
	hunk-header-style = file line-number syntax bold
	keep-plus-minus-markers = true
	line-numbers = true
	line-numbers-left-format = "{nm:^4} "
	line-numbers-left-style = "#bac2de #1e2030"
	line-numbers-minus-style = "#f38ba8 #1e2030"
	line-numbers-plus-style = "#a6e3a1 #1e2030"
	line-numbers-right-format = "{np:^4} "
	line-numbers-right-style = "#bac2de #1e2030"
	line-numbers-zero-style = "#6c7086 #1e2030"
	minus-emph-style = syntax
	minus-non-emph-style = syntax
	minus-style = syntax "#38232f"
	navigate = true
	plus-emph-style = syntax
	plus-non-emph-style = syntax
	plus-style = syntax "#1f2d24"
	side-by-side = true
	syntax-theme = Catppuccin Mocha
	zero-style = normal

[diff]
	algorithm = histogram
	colorMoved = dimmed-zebra
	colorMovedWS = allow-indentation-change
	compactionHeuristic = true
	indentHeuristic = true

[fetch]
	writeCommitGraph = true

[gc]
	writeCommitGraph = true

[difftool]
	prompt = false
	tool = vimdiff

[difftool "vimdiff"]
	path = nvim

[help]
	autocorrect = prompt

[init]
	defaultBranch = main

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictStyle = zdiff3
	tool = vimdiff

[mergetool "vimdiff"]
	path = nvim

[pull]
	ff = only
	rebase = true

[status]
	aheadBehind = true

[remote "origin"]
	prune = true
	pruneTags = true

[push]
	autoSetupRemote = true
	default = current
	followTags = true

[rebase]
	autoSquash = true
	autoStash = true
	instructionFormat = (%an <%ae>) %s
	updateRefs = true

[rerere]
	enabled = 1

