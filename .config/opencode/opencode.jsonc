{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "skill": {
      "*": "deny"
    }
  },
  "agent": {
    "plan": {
      "color": "#b8bb26",
      "permission": {
        "skill": {
          "research-brief": "allow",
          "ci-triage": "allow",
          "jira-context-resolver": "allow",
          "local-agent-tools-usage": "allow"
        }
      }
    },
    "build": {
      "color": "#fb4934",
      "tools": {
        "skill": false
      }
    },
    "review": {
      "tools": {
        "skill": false
      }
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "node:22-alpine",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "searxng": {
      "type": "local",
      "command": [
        "uvx",
        "git+https://github.com/sethamclean/search-mcp/"
      ],
      "environment": {
        "SEARXNG_API_URL": "{env:SEARXNG_API_URL}"
      },
      "enabled": true
    },
    "atlassian_remote": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "JIRA_USERNAME",
        "-e",
        "JIRA_API",
        "node:22-alpine",
        "sh",
        "-lc",
        "AUTH=$(printf '%s:%s' \"$JIRA_USERNAME\" \"$JIRA_API\" | base64 | tr -d '\\n'); exec npx -y mcp-remote@latest https://mcp.atlassian.com/v1/mcp --header \"Authorization: Basic $AUTH\""
      ],
      "environment": {
        "JIRA_USERNAME": "{env:JIRA_USERNAME}",
        "JIRA_API": "{env:JIRA_API}"
      },
      "enabled": false
    }
  },
}
